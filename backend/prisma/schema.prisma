generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Company {
  id               String            @id @default(uuid())
  name             String
  domain           String            @unique
  plan             String            @default("free")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  auditLogs        AuditLog[]
  candidates       Candidate[]
  documents        Document[]
  documentRequests DocumentRequest[]
  employees        Employee[]
  evaluations      Evaluation[]
  eventLogs        EventLog[]
  jobs             Job[]
  users            User[]
  workflowStates   WorkflowState[]
}

model User {
  id               String            @id @default(uuid())
  email            String
  password         String
  name             String
  role             String            @default("CANDIDATE")
  status           String            @default("ACTIVE")
  lastLogin        DateTime?
  companyId        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  auditLogs        AuditLog[]
  documentRequests DocumentRequest[]
  evaluations      Evaluation[]
  company          Company?          @relation(fields: [companyId], references: [id])

  @@unique([email, companyId])
}

model Job {
  id           String      @id @default(uuid())
  title        String
  description  String
  requirements String
  department   String?
  salary       String?
  status       String      @default("OPEN")
  companyId    String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  candidates   Candidate[]
  company      Company     @relation(fields: [companyId], references: [id])
}

model Candidate {
  id              String         @id @default(uuid())
  name            String
  email           String
  phone           String?
  resumeUrl       String?
  resumeText      String?
  skills          String         @default("[]")
  experienceYears Int            @default(0)
  score           Float          @default(0)
  status          String         @default("APPLIED")
  aiSummary       String?
  jobId           String?
  companyId       String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  company         Company        @relation(fields: [companyId], references: [id])
  job             Job?           @relation(fields: [jobId], references: [id])
  documents       Document[]
  employee        Employee?
  evaluations     Evaluation[]
  workflowState   WorkflowState?
}

model Evaluation {
  id              String    @id @default(uuid())
  candidateId     String
  evaluatorId     String
  companyId       String
  technicalScore  Float     @default(0)
  softSkillScore  Float     @default(0)
  motivationScore Float     @default(0)
  globalScore     Float     @default(0)
  notes           String?
  feedback        String?
  decision        String    @default("PENDING")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id])
  evaluator       User      @relation(fields: [evaluatorId], references: [id])
  candidate       Candidate @relation(fields: [candidateId], references: [id])
}

model WorkflowState {
  id          String    @id @default(uuid())
  candidateId String    @unique
  companyId   String
  state       String    @default("APPLIED")
  history     String    @default("[]")
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id])
  candidate   Candidate @relation(fields: [candidateId], references: [id])
}

model Employee {
  id               String    @id @default(uuid())
  candidateId      String    @unique
  companyId        String
  department       String?
  position         String?
  salary           Float?
  startDate        DateTime  @default(now())
  performanceScore Float     @default(0)
  riskScore        Float     @default(0)
  riskLevel        String    @default("LOW")
  status           String    @default("ACTIVE")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  company          Company   @relation(fields: [companyId], references: [id])
  candidate        Candidate @relation(fields: [candidateId], references: [id])
}

model Document {
  id          String     @id @default(uuid())
  type        String
  title       String
  content     String
  candidateId String?
  companyId   String
  status      String     @default("GENERATED")
  createdAt   DateTime   @default(now())
  company     Company    @relation(fields: [companyId], references: [id])
  candidate   Candidate? @relation(fields: [candidateId], references: [id])
}

model DocumentRequest {
  id              String    @id @default(uuid())
  type            String
  title           String
  description     String?
  urgency         String    @default("normal")
  status          String    @default("PENDING")
  requestedAt     DateTime  @default(now())
  processedAt     DateTime?
  documentUrl     String?
  rejectionReason String?
  userId          String
  companyId       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
}

model EventLog {
  id          String   @id @default(uuid())
  event       String
  payload     String
  companyId   String?
  processedAt DateTime @default(now())
  company     Company? @relation(fields: [companyId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  companyId  String?
  action     String
  resource   String
  resourceId String?
  details    String?
  ip         String?
  createdAt  DateTime @default(now())
  company    Company? @relation(fields: [companyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}
